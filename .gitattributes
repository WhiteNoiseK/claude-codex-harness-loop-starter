# Line-ending normalization — the repo standardizes on LF. Shell scripts (.sh) must keep LF
# (CRLF breaks bash scripts under Git Bash/Linux). This matters because the harness gates are .sh.
* text=auto
*.sh    text eol=lf
*.py    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text
*.txt   text
*.png   binary
*.jpg   binary
*.gif   binary
