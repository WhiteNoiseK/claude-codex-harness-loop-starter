# Dependencies
node_modules/

# OS-generated files
.DS_Store
Thumbs.db

# Environments
.env
.venv/

# Editor directories and files
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln

# ECC install state (regenerated by installer)
.agent/ecc-install-state.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
