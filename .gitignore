site/
.cache/

# Harness runtime artifacts (regenerated each run — not committed)
docs/ai-workflow/research_temp.md
docs/ai-workflow/_*.txt
.harness/baseline/*.actual

# Temp/scratch files
.tmp/
*.tmp
*.bak
*.swp
